FROM node:22-slim AS builder

WORKDIR /app

COPY package.json package-lock.json ./
COPY packages/timetoprod-web/package.json ./packages/timetoprod-web/

RUN npm install --workspace=packages/timetoprod-web

COPY packages/timetoprod-web/ ./packages/timetoprod-web/

ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build --workspace=packages/timetoprod-web

FROM node:22-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3001

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/packages/timetoprod-web/.next/standalone ./
COPY --from=builder /app/packages/timetoprod-web/.next/static ./packages/timetoprod-web/.next/static
COPY --from=builder /app/packages/timetoprod-web/public ./packages/timetoprod-web/public 2>/dev/null || true

USER nextjs

EXPOSE 3001

CMD ["node", "packages/timetoprod-web/server.js"]
