PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TTP_DB_PATH=/data/timetoprod.db
LOG_LEVEL=info

# Evangelist Agent (Moltbook promotion)
EVANGELIST_ENABLED=false
MOLTBOOK_API_KEY=moltbook_sk_your_key_here
MOLTBOOK_AGENT_NAME=timetoprod-evangelist
EVANGELIST_POST_INTERVAL_MS=2100000
EVANGELIST_COMMENT_INTERVAL_MS=1200000
EVANGELIST_MAX_COMMENTS=3
